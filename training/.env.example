# ============================================================
# Datenbank-Konfiguration für Export-Training-Daten
# ============================================================

# MariaDB/MySQL Verbindung (via Docker: Port 3307, siehe import_db.ps1)
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=schreibdienst
DB_NAME=schreibdienst

# Pfad zum SQL-Dump (relativ zum Skript)
DUMP_PATH=../../database/schreibdienst-db-2026-07-11.sql

# Ausgabeverzeichnis für exportierte Trainingsdaten
OUTPUT_DIR=../../data

# Anzahl paralleler Worker für Audio-Konvertierung
WORKERS=4

# Ziel-Sampling-Rate für Audio-Export (Hz)
TARGET_SR=16000

# Chunking-Parameter
CHUNK_DURATION=30.0       # Sekunden pro Chunk
CHUNK_OVERLAP=0.25        # 25% Overlap zwischen Chunks
MAX_DURATION_FULL=180.0   # Sekunden – Diktate darunter bleiben ohne Chunking

# Test-Modus: Nur N Diktate exportieren (0 = alle)
LIMIT=0
